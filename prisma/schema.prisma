generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Role {
  ADMIN
  HOST
  GUEST

}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// --- Models ---

model ListingPhoto {
  id      Int       @id @default(autoincrement())
  url     String
  publicId String
  listing Listing   @relation(fields: [listingId], references: [id])
  listingId Int
  createdAt DateTime @default(now())
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  username  String    @unique
  phone     String
  role      Role      @default(GUEST)
  password  String    @default("changeme")
  avatar    String?
  avatarPublicId String?
  bio       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  resetToken String?
  resetTokenExpiry DateTime?


  // Relations
  listings  Listing[] @relation("HostListings")
  bookings  Booking[] @relation("GuestBookings")
  reviews  Review[]
}

model Listing {
  id            Int         @id @default(autoincrement())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String[]
  rating        Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relation to User (Host)
  host          User        @relation("HostListings", fields: [hostId], references: [id])
  hostId        Int

  // Relation to Photos
  photos        ListingPhoto[]

  // Relation to Bookings
  bookings      Booking[]

  @@index([location])
  @@index([type])
  @@index([pricePerNight])
}
model Booking {
  id         Int           @id @default(autoincrement())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  guests     Int           @default(1)
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  // Relation to User (Guest)
  guest      User          @relation("GuestBookings", fields: [guestId], references: [id])
  guestId    Int

  // Relation to Listing
  listing    Listing       @relation(fields: [listingId], references: [id])
  listingId  Int
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  listingId Int
}